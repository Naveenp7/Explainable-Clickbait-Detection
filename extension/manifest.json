{
  "manifest_version": 3,
  "name": "Explainable Clickbait Detector",
  "version": "1.0.0",
  "description": "Detects clickbait headlines and explains the prediction using AI.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Clickbait Settings"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["style.css"],
      "js": ["content.js"]
    }
  ]
}
